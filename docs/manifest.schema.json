{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tabularium.wiki/manifest.schema.json",
  "title": "Tabularium plugin manifest",
  "description": "Plugin authors drop a .tabularium / .tabularium.yaml / .tabularium.yml / .tabularium.json at the repo root.",
  "type": "object",
  "properties": {
    "name": {
      "minLength": 1,
      "maxLength": 60,
      "type": "string"
    },
    "description": {
      "maxLength": 280,
      "type": "string"
    },
    "category": {
      "maxLength": 40,
      "type": "string"
    },
    "kind": {
      "minLength": 1,
      "maxLength": 40,
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "type": "string"
    },
    "tags": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "maxLength": 30,
        "type": "string"
      }
    },
    "license": {
      "maxLength": 40,
      "type": "string"
    },
    "icon": {
      "maxLength": 500,
      "type": "string"
    },
    "screenshots": {
      "maxItems": 12,
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "minLength": 1,
            "maxLength": 500,
            "type": "string"
          },
          "caption": {
            "maxLength": 200,
            "type": "string"
          },
          "alt": {
            "maxLength": 200,
            "type": "string"
          }
        }
      }
    },
    "readme": {
      "maxLength": 500,
      "type": "string"
    },
    "documentation_url": {
      "pattern": "^https?://.+",
      "type": "string"
    },
    "homepage": {
      "pattern": "^https?://.+",
      "type": "string"
    },
    "support": {
      "type": "object",
      "properties": {
        "email": {
          "maxLength": 254,
          "type": "string"
        },
        "issues_url": {
          "pattern": "^https?://.+",
          "type": "string"
        }
      }
    },
    "min_runtime_version": {
      "maxLength": 40,
      "type": "string"
    }
  }
}
