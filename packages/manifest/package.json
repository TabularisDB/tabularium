{
  "name": "@tabularium/manifest",
  "version": "0.2.0",
  "description": "Pure validator + integrity primitives for the Tabularium plugin manifest (`.tabularium` / `tabularium.yaml` / `tabularium.json`).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://codeberg.org/Tabularium/Tabularium.git",
    "directory": "packages/manifest"
  },
  "homepage": "https://tabularium.wiki",
  "keywords": [
    "tabularium",
    "plugin-registry",
    "manifest",
    "validator",
    "integrity"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tabularium/tsconfig": "workspace:*"
  }
}
