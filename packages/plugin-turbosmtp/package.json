{
  "name": "@tabularium/plugin-turbosmtp",
  "version": "1.2.0",
  "description": "Tabularium first-party TurboSMTP email provider plugin.",
  "private": true,
  "type": "module",
  "main": "./src/api/index.ts",
  "module": "./src/api/index.ts",
  "types": "./src/api/index.ts",
  "exports": {
    ".": {
      "types": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    },
    "./frontend/*.svelte": "./src/frontend/*.svelte",
    "./frontend/*.load": {
      "types": "./src/frontend/*.load.ts",
      "default": "./src/frontend/*.load.ts"
    },
    "./frontend/*": {
      "types": "./src/frontend/*.ts",
      "svelte": "./src/frontend/*.svelte",
      "default": "./src/frontend/*.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@tabularium/plugin-email": "workspace:*",
    "@tabularium/plugin-host-types": "workspace:*",
    "@tabularium/tsconfig": "workspace:*"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "turbosmtp": "./vendor/turbosmtp-0.1.0.tgz"
  }
}
