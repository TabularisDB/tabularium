{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"rewriteRelativeImportExtensions": true,
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"moduleResolution": "bundler"
	}
	// NOTE: Frontend type-check has ~18 transitive-resolution errors from
	// apps/api/src/index.ts (uses $lib/* aliases that the frontend tsconfig
	// can't see). These don't affect runtime — the API + frontend each
	// build correctly via their own tooling. Proper fix requires either
	// TypeScript project references (composite mode) or extracting the
	// App-defining chain into a file with relative imports.
}
