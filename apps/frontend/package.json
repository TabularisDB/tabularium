{
	"name": "@tabularium/registry-frontend",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "NODE_OPTIONS=--no-deprecation vite dev --port 5180",
		"build": "bun scripts/sync-plugin-messages.ts && vite build",
		"preview": "vite preview",
		"prepare": "bun scripts/sync-plugin-messages.ts && svelte-kit sync || echo ''",
		"check": "bun scripts/sync-plugin-messages.ts && paraglide-js compile --project project.inlang --outdir src/lib/paraglide --silent && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun scripts/sync-plugin-messages.ts && paraglide-js compile --project project.inlang --outdir src/lib/paraglide --silent && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"machine-translate": "inlang machine translate --project project.inlang"
	},
	"devDependencies": {
		"@inlang/cli": "^3.0.0",
		"@inlang/paraglide-js": "^2.18.0",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tabularium/tsconfig": "workspace:*",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.8.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.6.0",
		"vite": "^7.0.0"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.0",
		"@lezer/highlight": "^1.2.3",
		"@lucide/svelte": "^1.3.0",
		"@tabularium/client": "workspace:*",
		"@tabularium/plugin-discord-notifier": "workspace:*",
		"@tabularium/plugin-email": "workspace:*",
		"@tabularium/plugin-turbosmtp": "workspace:*",
		"@tanstack/svelte-query": "^5.62.0",
		"bits-ui": "^2.4.1",
		"clsx": "^2.1.1",
		"elysia": "^1.4.28",
		"layerchart": "^2.0.0-next.64",
		"mode-watcher": "^1.0.7",
		"svelte-jsoneditor": "3.12.0",
		"svelte-sonner": "^1.0.0",
		"tailwind-merge": "^3.0.0",
		"tailwind-variants": "^1.0.0"
	}
}
