{
  "name": "@tabularium/api",
  "version": "0.0.0",
  "private": true,
  "module": "src/index.ts",
  "types": "src/types.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/types.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts"
    }
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "start": "bun src/index.ts",
    "build": "echo 'no build step — Bun runs TS directly'",
    "check": "tsc --noEmit",
    "test": "bun test",
    "seed": "bun src/db/seed.ts",
    "migrate": "bun src/db/migrate.ts",
    "generate": "bunx drizzle-kit generate",
    "generate:pg": "bunx drizzle-kit generate --config=drizzle.pg.config.ts",
    "generate:mysql": "bunx drizzle-kit generate --config=drizzle.mysql.config.ts",
    "export:manifest-schema": "bun scripts/export-manifest-schema.ts"
  },
  "devDependencies": {
    "@tabularium/tsconfig": "workspace:*",
    "drizzle-kit": "^1.0.0-rc.2",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@tabularium/manifest": "workspace:*",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.5",
    "@elysiajs/static": "^1.4.10",
    "@sinclair/typebox": "^0.34.49",
    "arctic": "^3.7.0",
    "drizzle-orm": "^1.0.0-rc.2",
    "elysia": "^1.4.28",
    "elysia-file-router": "file:../../vendor/elysia-file-router/elysia-file-router-0.0.1.tgz",
    "isomorphic-dompurify": "^3.12.0",
    "jose": "^6.2.3",
    "marked": "^18.0.3",
    "mysql2": "^3.22.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "ulid": "^3.0.2",
    "yaml": "^2.9.0"
  }
}
