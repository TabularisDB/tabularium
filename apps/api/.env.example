# DATABASE_URL — pick one. The scheme selects the driver and migration dir.
#   sqlite:    ./data/registry.db       (default — no migration setup needed)
#   postgres:  postgres://user:pass@host:5432/dbname
#   mysql:     mysql://user:pass@host:3306/dbname
# For postgres/mysql you must first run:
#   DATABASE_URL=… bun run generate:pg     (creates ./src/db/migrations.pg)
#   DATABASE_URL=… bun run generate:mysql  (creates ./src/db/migrations.mysql)
# then start the backend — migrations apply on first boot.
DATABASE_URL=./data/registry.db

# OAuth: GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth: GitLab.com
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# OAuth: Codeberg.org
CODEBERG_CLIENT_ID=
CODEBERG_CLIENT_SECRET=

# REQUIRED. Min 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=

# REQUIRED. AES-256-GCM key for encrypting OAuth tokens at rest.
# Must be exactly 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
TOKEN_ENC_KEY=

BASE_URL=http://localhost:3000
# Where to send the user after OAuth completes. Defaults to BASE_URL.
# In dev, set this to the Vite dev server URL so the user lands back there with cookies intact.
WEB_BASE_URL=http://localhost:5180

# Extra CORS origins (comma-separated). BASE_URL + WEB_BASE_URL are always allowed.
# In dev, localhost:5180 / 127.0.0.1:5180 are auto-added.
# ALLOWED_ORIGINS=https://staging.example.com,https://preview.example.com

# Cache driver — initial value only. Once an admin saves a driver in /admin/infra
# the setting in the DB takes precedence. Values: off, memory, redis.
CACHE_DRIVER=memory
# REDIS_URL=redis://localhost:6379

PORT=3000
