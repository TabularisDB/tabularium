{
  "name": "tabularis-registry",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "migrate": "bun --cwd apps/api run migrate",
    "generate": "bun --cwd apps/api run generate",
    "seed": "bun --cwd apps/api run seed"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.5.6",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "elysia": "^1.4.28"
  },
  "packageManager": "bun@1.3.12"
}
